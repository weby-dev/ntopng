# =============================================================================
# config/.env — Environment Variables
# Copy to: /opt/ntopng-analyzer/config/.env
# Protect:  chmod 600 /opt/ntopng-analyzer/config/.env
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=ntopng_user
DB_PASSWORD=your_strong_password_here
DB_NAME=ntopng_threats

# ── Log Paths ─────────────────────────────────────────────────────────────────
LOG_BASE_DIR=/var/log/remote
SCRIPT_LOG=/var/log/ntopng_analyzer/analyzer.log

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_TLS=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noc@yourdomain.com
SMTP_FROM_NAME=NOC Security Team

# ── Cron ──────────────────────────────────────────────────────────────────────
# Comma-separated CC email addresses added to all abuse reports
VICTIM_CC_EMAILS=noc@yourdomain.com,security@yourdomain.com

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8765
API_TOKEN=replace-with-a-long-random-secret-token
